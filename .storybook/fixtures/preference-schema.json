{
  "ui.locale": {
    "type": "string",
    "descriptionKey": "ui.locale.description",
    "enum": ["en", "es", "fr"],
    "default": "en",
    "scope": "global",
    "overridable": true
  },
  "editor.fontSize": {
    "type": "number",
    "descriptionKey": "editor.fontSize.description",
    "default": 14,
    "minimum": 10,
    "maximum": 32,
    "scope": "user",
    "overridable": false
  },
  "ui.compact": {
    "type": "boolean",
    "descriptionKey": "ui.compact.description",
    "default": false,
    "scope": "application",
    "overridable": true
  },
  "profile.displayName": {
    "type": "string",
    "descriptionKey": "profile.displayName.description",
    "minLength": 3,
    "maxLength": 64,
    "default": "Jane Doe",
    "scope": "user",
    "overridable": true
  },
  "tags.stringList": {
    "type": "array",
    "items": { "type": "string" },
    "descriptionKey": "tags.stringList.description",
    "minItems": 1,
    "maxItems": 8,
    "default": ["alpha", "beta"],
    "scope": "application",
    "overridable": true
  },
  "thresholds.numberList": {
    "type": "array",
    "items": { "type": "number" },
    "descriptionKey": "thresholds.numberList.description",
    "default": [10, 20],
    "scope": "system",
    "overridable": false
  },
  "flags.booleanList": {
    "type": "array",
    "items": { "type": "boolean" },
    "descriptionKey": "flags.booleanList.description",
    "default": [true, false],
    "scope": "global",
    "overridable": true
  },
  "ui.enabledLocales": {
    "type": "array",
    "items": { "type": "string" },
    "descriptionKey": "ui.enabledLocales.description",
    "default": ["en", "es"],
    "scope": "application",
    "overridable": true
  },
  "network.allowedPorts": {
    "type": "array",
    "items": { "type": "number" },
    "descriptionKey": "network.allowedPorts.description",
    "scope": "system",
    "overridable": true,
    "default": [80, 443]
  }
}
