{
  "editor.theme.mode": {
    "type": "string",
    "scope": "system",
    "overridable": true,
    "enum": [
      "light",
      "dark",
      "highContrast"
    ],
    "default": "light",
    "description": "Visual theme mode for the editor."
  },
  "editor.font.size": {
    "type": "number",
    "scope": "global",
    "overridable": true,
    "minimum": 10,
    "maximum": 32,
    "default": 14,
    "description": "Editor font size in pixels."
  },
  "editor.font.family": {
    "type": "string",
    "scope": "application",
    "overridable": false,
    "default": "Fira Code",
    "description": "Primary editor font family."
  },
  "editor.extensions.enabled": {
    "type": "array",
    "items": {
      "type": "string"
    },
    "scope": "application",
    "overridable": true,
    "minItems": 0,
    "default": [
      "spellcheck",
      "formatter"
    ],
    "description": "Enabled editor extensions."
  },
  "assistant.hints.enabled": {
    "type": "boolean",
    "scope": "user",
    "overridable": false,
    "default": true,
    "description": "Enable assistant hints."
  },
  "workspace.shortcuts": {
    "type": "object",
    "scope": "system",
    "overridable": false,
    "default": {
      "save": "CmdOrCtrl+S",
      "open": "CmdOrCtrl+O"
    },
    "description": "Shortcut mapping for core workspace actions."
  },
  "notifications.digest.hours": {
    "type": "array",
    "items": {
      "type": "number"
    },
    "scope": "global",
    "overridable": true,
    "default": [
      9,
      17
    ],
    "description": "Hours for sending digest notifications."
  },
  "editor.font.advanced.ligatures.enabled": {
    "type": "boolean",
    "scope": "application",
    "overridable": true,
    "default": true,
    "description": "Enable advanced ligatures in the editor font renderer."
  },
  "notifications.digest.schedule.weekdays": {
    "type": "array",
    "items": {
      "type": "string"
    },
    "scope": "global",
    "overridable": true,
    "default": [
      "monday",
      "wednesday",
      "friday"
    ],
    "description": "Weekdays used for digest schedule delivery."
  }
}